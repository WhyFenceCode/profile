---
import Home from '../components/Home.astro';

import Ressa from '../components/quotes/Ressa.astro';
import Obama from '../components/quotes/Obama.astro';
import Confucius from '../components/quotes/Confucius.astro';

import About from '../components/About.astro';
import Value from '../components/Value.astro';
import Experience from '../components/Experience.astro';

import MenuBar from '../components/MenuBar.astro';
import Layout from '../layouts/Layout.astro';
import "../styles/global.css";
---

<Layout>
	<MenuBar>
		<Home />
		<div class="w-full h-22" />
		<Ressa />
		<div class="w-full h-1/11" />
		<About />
		<div class="w-full h-1/15" />
		<Obama />
		<div class="w-full h-1/20" />
		<Value />
		<div class="w-full h-1/15" />
		<Confucius />
		<div class="w-full h-1/20" />
		<Experience />
		<div class="w-full h-22" />
	</MenuBar>
</Layout>
