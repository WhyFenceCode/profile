---
interface Props {
  sizeLarge?: boolean;
}

const {sizeLarge } = Astro.props;

const basicStyle = "uppercase text-gray-900 bg-amber-400 font-[950] font-main tracking-widest"

const Element = sizeLarge === true ? 'h2' : 'p';
const ElementStyle = sizeLarge === true ? (basicStyle + " py-2 px-4 text-sm") : (basicStyle + " py-1 px-3 text-[0.69rem]");
---

<Element class={ElementStyle}><slot /></Element>

